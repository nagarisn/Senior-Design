# Copy this file to .env and fill in your values
# The app works without any keys — it falls back to mock data automatically

# Duffel API (Flights) — https://duffel.com
DUFFEL_ACCESS_TOKEN=""

# Viator API (Activities) — https://viator.com/partner
VIATOR_API_KEY=""

# Email / SMTP (optional — logs to console if not set)
# Gmail: use an App Password from https://myaccount.google.com/apppasswords
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""

# JWT secret — change this in production
JWT_SECRET_KEY="smart_travel_secret_2024"

# Production CORS — set to your Railway frontend URL (e.g. https://smart-travel-frontend.up.railway.app)
ALLOWED_ORIGINS="*"
